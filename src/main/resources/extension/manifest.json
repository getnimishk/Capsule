{
  "manifest_version": 3,
  "name": "Capsule",
  "version": "2.0.0",
  "author": "Nimish Kanungo",
  "homepage_url": "https://github.com/nimishkanungo",
  "description": "Capsule by Nimish Kanungo - Capture and sync AI conversations from Claude, ChatGPT, Gemini, DeepSeek, Perplexity, Grok, Mistral, and Kimi into NotebookLM.",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "unlimitedStorage"
  ],

  "host_permissions": [
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://chat.deepseek.com/*",
    "https://www.perplexity.ai/*",
    "https://x.com/*",
    "https://chat.mistral.ai/*",
    "https://kimi.ai/*",
    "https://notebooklm.google/*",
    "https://notebooklm.google.com/*"
  ],

  "optional_host_permissions": [
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://api.groq.com/*",
    "https://openrouter.ai/*",
    "http://localhost:11434/*",
    "https://generativelanguage.googleapis.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.claude.ai/*",
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*",
        "https://chat.deepseek.com/*",
        "https://*.deepseek.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://*.perplexity.ai/*",
        "https://x.com/*",
        "https://grok.com/*",
        "https://*.grok.com/*",
        "https://chat.mistral.ai/*",
        "https://*.mistral.ai/*",
        "https://kimi.ai/*",
        "https://*.kimi.ai/*",
        "https://kimi.moonshot.cn/*"
      ],
      "js": ["shared/api_hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.claude.ai/*"],
      "js": ["shared/token_estimator.js", "content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["shared/token_estimator.js", "injectors/gemini.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chatgpt.com/*", "https://*.chatgpt.com/*"],
      "js": ["shared/token_estimator.js", "injectors/chatgpt.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chat.deepseek.com/*", "https://*.deepseek.com/*"],
      "js": ["shared/token_estimator.js", "injectors/deepseek.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.perplexity.ai/*", "https://perplexity.ai/*", "https://*.perplexity.ai/*"],
      "js": ["shared/token_estimator.js", "injectors/perplexity.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://x.com/*", "https://grok.com/*", "https://*.grok.com/*"],
      "js": ["shared/token_estimator.js", "injectors/grok.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chat.mistral.ai/*", "https://*.mistral.ai/*"],
      "js": ["shared/token_estimator.js", "injectors/mistral.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://kimi.ai/*", "https://*.kimi.ai/*", "https://kimi.moonshot.cn/*"],
      "js": ["shared/token_estimator.js", "injectors/kimi.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://notebooklm.google/*",
        "https://notebooklm.google.com/*"
      ],
      "js": ["injectors/notebooklm.js"],
      "run_at": "document_idle"
    }
  ],

  "options_page": "options/options.html",

  "web_accessible_resources": [
    {
      "resources": ["shared/selectors.js", "shared/nlp_compress.js", "shared/llm_client.js", "shared/token_estimator.js"],
      "matches": [
        "*://*.claude.ai/*",
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*",
        "https://chat.deepseek.com/*",
        "https://*.deepseek.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://*.perplexity.ai/*",
        "https://chat.mistral.ai/*",
        "https://*.mistral.ai/*",
        "https://kimi.ai/*",
        "https://*.kimi.ai/*",
        "https://x.com/*",
        "https://grok.com/*",
        "https://*.grok.com/*",
        "https://notebooklm.google/*",
        "https://notebooklm.google.com/*"
      ]
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Capsule",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}


